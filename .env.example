# ── IG Agent 環境変数 ──

# Neon Postgres
DATABASE_URL="postgresql://user:pass@host/igagent?sslmode=require"

# 認証（NextAuth v5）
AUTH_SECRET=          # openssl rand -base64 32
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# IGトークン暗号化（AES-256-GCM）
ENCRYPTION_KEY=       # openssl rand -hex 32（64文字hex）

# Instagram API with Instagram Login
# Meta開発者アプリ（https://developers.facebook.com/apps/）で
# 「Instagram」プロダクト > API setup with Instagram business login を設定して取得
IG_APP_ID=
IG_APP_SECRET=

# AI 生成（構成=Claude / 背景画像=gpt-image-1。OPENAI未設定でもグラデーション背景で動作）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# /api/cron 保護（Cloud Scheduler から Bearer で渡す）
CRON_SECRET=

# Googleログイン（任意）
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
