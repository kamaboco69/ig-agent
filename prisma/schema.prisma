// IG Agent — Instagram 自動運用ツール
// 構成は X Agent (x-step) を踏襲（Next.js 16 + Prisma 7 + NextAuth v5 マルチテナント）

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// マルチテナント基盤（認証 + 組織）
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  ownerId   String?
  plan      String   @default("free") // free / light / standard / pro
  suspended Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  igAccounts IgAccount[]
  stories    Story[]
  driveIntegration DriveIntegration?
}

// メディアライブラリ用の Google ドライブ連携（組織ごとに1件）。
// 指定フォルダ内の画像/動画をストーリーズ素材として使う。トークンは暗号化保存。
model DriveIntegration {
  id             String    @id @default(cuid())
  organizationId String    @unique
  googleEmail    String?
  folderId       String? // 素材フォルダのID（URL貼り付けから抽出）
  folderName     String?
  accessToken    String // 暗号化
  refreshToken   String? // 暗号化（offline access）
  tokenExpiresAt DateTime?
  status         String    @default("connected") // connected / expired / revoked
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String? // Credentials ログイン用
  role           String    @default("user") // user / admin
  organizationId String?
  createdAt      DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  accounts     Account[]
  sessions     Session[]

  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Instagram 運用ドメイン（すべて organizationId でスコープ）
// ─────────────────────────────────────────────

// 連携した Instagram プロアカウント（Instagram API with Instagram Login）。
// トークンは長期トークン（60日）をアプリ層で暗号化して保存し、cron で自動更新する。
model IgAccount {
  id             String    @id @default(cuid())
  organizationId String
  igUserId       String // Instagram のユーザーID（graph.instagram.com /me の user_id）
  username       String // @ なしのハンドル
  name           String?
  avatarUrl      String?
  accountType    String? // BUSINESS / MEDIA_CREATOR
  accessToken    String // 長期トークン（lib/crypto.ts の AES-256-GCM で暗号化）
  tokenExpiresAt DateTime? // 長期トークンの期限（約60日。cronが自動リフレッシュ）
  scope          String?
  status         String    @default("connected") // connected / expired / revoked

  // ストーリーズ自動運用（オートパイロット）
  autoStoryEnabled Boolean   @default(false)
  autoStoryTimes   String? // 自動投稿時刻（JST, "08:00,20:00" 形式）
  autoStoryTheme   String? // 自動生成のテーマ・方向性（自由記述。生成プロンプトに注入）
  autoStoryStyle   String    @default("auto") // 画像スタイル（story-generator の IMAGE_STYLES キー）
  autoStorySource  String    @default("ai") // ai（全AI生成）/ library（ドライブ素材から）/ mix（交互）
  lastAutoStoryAt  DateTime? // 最後に自動生成した日時（同一スロットの二重実行防止）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stories      Story[]

  @@unique([organizationId, igUserId])
  @@index([organizationId])
}

// ストーリーズ投稿（AI生成 → 下書き → 即時/予約投稿）。
// 画像は DB に data URL(JPEG) で保持し、/api/story-image/[id] で公開配信する
// （IG の media 取り込みは公開URLが必須。App Hosting では public/ が配信されないため）。
model Story {
  id             String    @id @default(cuid())
  organizationId String
  igAccountId    String
  concept        String? // AIが立てた構成メモ（テーマ・狙い）
  overlayTitle   String? // 画像に焼き込んだメインコピー
  overlaySub     String? // 画像に焼き込んだサブコピー
  imagePrompt    String? // 背景画像の生成プロンプト（英語）
  imageData      String // 画像: 投稿画像そのもの / 動画: サムネイル（data URL）
  mediaType      String    @default("image") // image / video
  sourceKind     String    @default("ai") // ai（全AI生成）/ upload / library（ドライブ）/ ig（過去投稿）
  sourceRef      String? // 素材の参照（drive:<fileId> / ig:<mediaId>）。重複利用の回避に使う
  videoSrc       String? // 動画の取得元URL（https直リンク）または "drive:<fileId>"（プロキシ配信）
  videoToken     String? // 動画プロキシ(/api/story-video)のアクセストークン
  status         String    @default("draft") // draft / scheduled / posting / posted / failed
  source         String    @default("manual") // manual（画面から生成）/ auto（オートパイロット）
  scheduledAt    DateTime?
  postedAt       DateTime?
  igMediaId      String? // 公開後の IG メディアID
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  igAccount    IgAccount    @relation(fields: [igAccountId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([scheduledAt])
}
